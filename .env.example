# Genera una clave segura con: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# Genera una clave Fernet con: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=cambia-esto-por-clave-fernet

# Puerto (opcional, default 8080)
PORT=8080
